{
  "manifest_version": 3,
  "name": "SourceTracker Helper",
  "description": "Capture visited pages into SourceTracker projects.",
  "version": "0.1.1",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_title": "SourceTracker",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
